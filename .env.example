# ============================================================
# AI Audiobook Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Storage — Backblaze B2 (S3-compatible)
# ------------------------------------------------------------------
STORAGE_BACKEND=b2
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_ID=
B2_BUCKET_NAME=
B2_REGION=us-west-004

# ------------------------------------------------------------------
# Parsers
# ------------------------------------------------------------------
PDF_PARSER=docling
OCR_BACKEND=rapidocr

# ------------------------------------------------------------------
# Chunker
# ------------------------------------------------------------------
CHUNKER=paragraph
CHUNK_MAX_CHARS=800

# ------------------------------------------------------------------
# TTS
# ------------------------------------------------------------------
TTS_PROVIDER=kokoro
TTS_VOICE=af_bella
TTS_SPEED=1.0

# ------------------------------------------------------------------
# LLM — local models only (see AGENTS.md §Local AI Strategy)
# ------------------------------------------------------------------
LLM_RUNTIME=ollama
LLM_MODEL=qwen2.5:0.5b
LLM_ORCHESTRATION=langgraph
LLM_STRUCTURED_OUTPUT=pydantic_ai

# ------------------------------------------------------------------
# NLP
# ------------------------------------------------------------------
SENTENCE_DETECTOR=spacy
G2P_BACKEND=espeak

# ------------------------------------------------------------------
# Experiment tracking
# ------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
LANGFUSE_HOST=http://localhost:3000

# ------------------------------------------------------------------
# OpenTelemetry → Tempo
# ------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-audiobook

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://audiobook:audiobook@localhost:5432/audiobook

# ------------------------------------------------------------------
# Redis / Celery
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ------------------------------------------------------------------
# API
# ------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
GIT_SHA=unknown
